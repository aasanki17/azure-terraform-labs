location                    = "Southeast Asia"
resource_group_name         = "rg-aztf-19"
virtual_network_name        = "vnet-aztf-19"
subnet_name                 = "snet-aztf-19-01"
network_security_group_name = "nsg-aztf-19"
availability_set_name       = "avset-aztf-19"

public_ip_name                 = "pip-aztf-19"
load_balancer_name             = "lb-aztf-19"
frontend_ip_configuration_name = "feip-aztf-19"
backend_pool_name              = "bpool-aztf-19"
health_probe_name              = "probe-http-aztf-19"
load_balancing_rule_name       = "rule-http-aztf-19"

network_interface_name_1 = "nic-aztf-19-01"
network_interface_name_2 = "nic-aztf-19-02"
ip_configuration_name_1  = "ipconfig-aztf-19-01"
ip_configuration_name_2  = "ipconfig-aztf-19-02"

windows_vm_name_1 = "vm-aztf-19-win1"
windows_vm_name_2 = "vm-aztf-19-win2"
os_disk_name_1    = "osdisk-vm-aztf-19-win-01"
os_disk_name_2    = "osdisk-vm-aztf-19-win-02"

vm_extension_name_1 = "vmext-iis-aztf-19-01"
vm_extension_name_2 = "vmext-iis-aztf-19-02"

admin_username = "aztfadmin"
admin_password = "<YOUR_STRONG_PASSWORD>"

dns_zone_name   = "yourdomain.com"
dns_record_name = "www"
dns_record_ttl  = 300
